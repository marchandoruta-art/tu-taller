      {
        "name": "add_vehicle_note",
        "title": "Añadir nota al vehículo",
        "description": "Añade una nota al resumen de trabajo (work_summary) o a las notas de recepción (reception_notes). Se añade al final con marca de tiempo.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": false
