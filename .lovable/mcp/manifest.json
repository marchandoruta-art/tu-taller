{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://vzinqlkktnzgciigtycx.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "tu-taller-mcp",
      "version": "0.1.0",
      "title": "Tu Taller MCP"
    },
    "tools": [
      {
        "name": "list_vehicles",
        "title": "Listar vehículos",
        "description": "Lista vehículos del taller del usuario autenticado. Permite filtrar por estado y buscar por matrícula/marca/modelo.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "recibido",
                "en_reparacion",
                "pendiente_piezas",
                "terminado",
                "entregado",
                "facturado"
              ],
              "description": "Filtra por estado del vehículo."
            },
            "search": {
              "type": "string",
              "minLength": 1,
              "maxLength": 50,
              "description": "Búsqueda por matrícula, marca o modelo."
            },
            "include_archived": {
              "type": "boolean",
              "description": "Incluir vehículos archivados. Por defecto false."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Máximo de resultados (por defecto 25)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_vehicle",
        "title": "Obtener vehículo",
        "description": "Devuelve el detalle completo de un vehículo por su id o por su matrícula.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "description": "ID del vehículo."
            },
            "plate": {
              "type": "string",
              "minLength": 1,
              "maxLength": 20,
              "description": "Matrícula del vehículo."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_appointments",
        "title": "Listar citas",
        "description": "Lista citas del taller en un rango de fechas (por defecto próximos 7 días).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "from": {
              "type": "string",
              "format": "date-time",
              "description": "Fecha inicial ISO 8601."
            },
            "to": {
              "type": "string",
              "format": "date-time",
              "description": "Fecha final ISO 8601."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
