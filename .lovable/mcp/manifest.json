          "readOnlyHint": false,
          "idempotentHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "vehicle_id": {
              "type": "string",
              "format": "uuid"
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "quantity": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "unit_price": {
              "type": "number",
              "minimum": 0
            },
            "reference": {
              "type": "string",
              "maxLength": 100
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          },
          "required": [
            "vehicle_id",
