            "field": {
              "type": "string",
              "enum": [
                "work_summary",
                "reception_notes"
              ],
              "description": "Por defecto work_summary."
            }
          },
          "required": [
            "vehicle_id",
            "note"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
